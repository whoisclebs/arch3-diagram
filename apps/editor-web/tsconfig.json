{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "Node",
    "rootDir": "src",
    "noEmit": true,
    "isolatedModules": true,
    "allowJs": false,
    "baseUrl": "src"
  },
  "include": [
    "src",
    "src/**/*.ts",
    "src/**/*.tsx",
    "react-app-env.d.ts"
  ]
}
