{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arch3.dev/schema/arch3/v0.1/arch3.schema.json",
  "title": "Arch3 Model v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["methodology", "scope", "context", "containers", "components"],
  "properties": {
    "methodology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "layers"],
      "properties": {
        "name": {
          "const": "Arch3"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "layers": {
          "type": "array",
          "items": {
            "enum": ["context", "containers", "components"]
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actors", "systems"],
      "properties": {
        "actors": {
          "type": "array",
          "items": { "$ref": "#/$defs/actor" }
        },
        "systems": {
          "type": "array",
          "items": { "$ref": "#/$defs/system" }
        }
      }
    },
    "containers": {
      "type": "array",
      "items": { "$ref": "#/$defs/container" }
    },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "description"],
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "container": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "system", "name", "technology", "description", "metadata", "relationships"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "system": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "technology": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "metadata": { "$ref": "#/$defs/metadata" },
        "relationships": {
          "type": "array",
          "items": { "$ref": "#/$defs/relationship" }
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "container", "name", "description", "libraries", "metadata", "relationships"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "container": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "libraries": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "metadata": { "$ref": "#/$defs/metadata" },
        "relationships": {
          "type": "array",
          "items": { "$ref": "#/$defs/relationship" }
        }
      }
    }
  }
}
