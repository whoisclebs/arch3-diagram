  "dependencies": {
    "ajv": "^8.17.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-schema.cjs",
    "test": "npm run build && tsx --test ./test/index.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
