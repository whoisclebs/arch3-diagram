@startuml Arch3
title Commerce Suite - components
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultTextAlignment center
skinparam linetype ortho
hide stereotype

!define ARCH3_ACTOR(name, alias) actor "name" as alias <<arch3_actor>>
!define ARCH3_SYSTEM(name, alias) rectangle "name\nSystem" as alias <<arch3_system>>
!define ARCH3_CONTAINER(name, tech, alias) rectangle "name\n[tech]" as alias <<arch3_container>>
!define ARCH3_COMPONENT(name, alias) rectangle "name" as alias <<arch3_component>>
!define ARCH3_LIBRARY(name, alias) artifact "name" as alias <<arch3_library>>

skinparam actor<<arch3_actor>> { BackgroundColor #EDE9FE; BorderColor #5B21B6 }
skinparam rectangle<<arch3_system>> { BackgroundColor #DBEAFE; BorderColor #1D4ED8 }
skinparam rectangle<<arch3_container>> { BackgroundColor #DCFCE7; BorderColor #15803D }
skinparam rectangle<<arch3_component>> { BackgroundColor #FEF3C7; BorderColor #B45309 }
skinparam artifact<<arch3_library>> { BackgroundColor #FCE7F3; BorderColor #BE185D }

ARCH3_ACTOR("Shopper", shopper)
package "Containers" {
ARCH3_CONTAINER("Web App", "React", web_app)
note right of web_app
metadata
owner: experience-squad
repo: github.com/whoisclebs/arch3-diagram
tier: critical
end note
ARCH3_CONTAINER("Checkout API", "Node.js", checkout_api)
note right of checkout_api
metadata
owner: payments-squad
runtime: container
end note
ARCH3_CONTAINER("Orders DB", "PostgreSQL", orders_db)
note right of orders_db
metadata
owner: data-platform
backup: enabled
end note
}

frame "Expanded container: Checkout API" {
ARCH3_COMPONENT("Checkout Service", checkout_service)
ARCH3_LIBRARY("express", checkout_service_lib_express)
checkout_service ..> checkout_service_lib_express : uses lib
ARCH3_LIBRARY("stripe", checkout_service_lib_stripe)
checkout_service ..> checkout_service_lib_stripe : uses lib
ARCH3_LIBRARY("prisma", checkout_service_lib_prisma)
checkout_service ..> checkout_service_lib_prisma : uses lib
ARCH3_COMPONENT("Orders Repository", orders_repository)
ARCH3_LIBRARY("prisma", orders_repository_lib_prisma)
orders_repository ..> orders_repository_lib_prisma : uses lib
}
checkout_service --> orders_repository : Stores the order
@enduml
